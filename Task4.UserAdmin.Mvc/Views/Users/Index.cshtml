@model UserManagementPageViewModel
@{
    ViewData["Title"] = "User Management";
}

<div class="d-flex flex-column gap-3">
    <div>
        <h1 class="h3 mb-1">User management</h1>
        <p class="text-muted mb-0">Sorted by last login time. Toolbar is always visible and row-level action buttons are intentionally not used.</p>
    </div>

    <form id="managementForm" method="post" class="card border-0 shadow-sm">
        <div class="card-body p-3 p-md-4">
            @Html.AntiForgeryToken()
            <input type="hidden" name="SearchTerm" value="@Model.SearchTerm" />

            <div class="toolbar d-flex flex-column flex-lg-row gap-3 justify-content-between align-items-start align-items-lg-center mb-3">
                <div class="btn-group" role="group" aria-label="Toolbar">
                    <button type="submit"
                            formaction="@Url.Action("BlockSelected", "Users")"
                            class="btn btn-outline-primary bulk-action"
                            data-bs-toggle="tooltip"
                            data-bs-title="Selected users will be blocked."
                            disabled>
                        <i class="bi bi-lock-fill me-1"></i>Block
                    </button>
                    <button type="submit"
                            formaction="@Url.Action("UnblockSelected", "Users")"
                            class="btn btn-outline-secondary bulk-action"
                            data-bs-toggle="tooltip"
                            data-bs-title="Remove block from selected users."
                            disabled>
                        <i class="bi bi-unlock-fill"></i>
                    </button>
                    <button type="submit"
                            formaction="@Url.Action("DeleteSelected", "Users")"
                            class="btn btn-outline-danger bulk-action"
                            data-bs-toggle="tooltip"
                            data-bs-title="Hard delete selected users."
                            disabled>
                        <i class="bi bi-trash"></i>
                    </button>
                    <button type="submit"
                            formaction="@Url.Action("DeleteUnverifiedSelected", "Users")"
                            class="btn btn-outline-danger bulk-action"
                            data-bs-toggle="tooltip"
                            data-bs-title="Delete only selected unverified users."
                            disabled>
                        <i class="bi bi-person-x"></i>
                    </button>
                </div>

                <div class="search-box ms-lg-auto">
                    <input id="userFilter" type="search" class="form-control" placeholder="Filter" value="@Model.SearchTerm" />
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0 user-table">
                    <thead>
                    <tr>
                        <th class="checkbox-col text-center">
                            <input type="checkbox" id="selectAllRows" class="form-check-input" aria-label="Select all" />
                        </th>
                        <th>Name</th>
                        <th>Email</th>
                        <th>Status</th>
                        <th>Last login</th>
                        <th>Created</th>
                    </tr>
                    </thead>
                    <tbody>
                    @foreach (var user in Model.Users)
                    {
                        <tr class="user-row" data-filter="@(user.FullName.ToLowerInvariant()) @(user.Email.ToLowerInvariant()) @(user.StatusText.ToLowerInvariant())">
                            <td class="text-center">
                                <input type="checkbox"
                                       name="SelectedUserIds"
                                       value="@user.Id"
                                       class="form-check-input row-selector"
                                       aria-label="Select row" />
                            </td>
                            <td>
                                <div class="fw-semibold">@user.FullName</div>
                            </td>
                            <td class="text-nowrap">@user.Email</td>
                            <td>
                                @if (user.IsBlocked)
                                {
                                    <span class="badge text-bg-secondary">Blocked</span>
                                }
                                else if (user.IsEmailVerified)
                                {
                                    <span class="badge text-bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge text-bg-warning">Unverified</span>
                                }
                            </td>
                            <td>@(user.LastLoginAtUtc.HasValue ? user.LastLoginAtUtc.Value.ToLocalTime().ToString("dd.MM.yyyy HH:mm:ss") : "Never")</td>
                            <td>@user.CreatedAtUtc.ToLocalTime().ToString("dd.MM.yyyy HH:mm:ss")</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        </div>
    </form>
</div>
